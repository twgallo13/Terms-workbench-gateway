# Development environment — copy to .env.local and fill in real values
# Get values from: firebase apps:sdkconfig WEB <app-id> --project twg-dev
NEXT_PUBLIC_FIREBASE_API_KEY=<from-firebase-console>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=twg-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=twg-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=twg-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<from-firebase-console>
NEXT_PUBLIC_FIREBASE_APP_ID=<from-firebase-console>
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
PDF_RENDERER_URL=http://localhost:8081

# Firebase Admin — server-side only
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
