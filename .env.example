# Terms Workbench Gateway (TWG) — Environment Variables
# Copy to .env.local and fill in real values

# Firebase Project Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-side only)
# Option A: path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
# Option B: JSON string (for CI/production)
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Environment
NEXT_PUBLIC_APP_ENV=development

# PDF Renderer Service (Cloud Run)
PDF_RENDERER_URL=http://localhost:8081

# App URL (used for access link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
